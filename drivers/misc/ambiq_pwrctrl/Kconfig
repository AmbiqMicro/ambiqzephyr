config AMBIQ_PWRCTRL
	bool "Ambiq shared peripheral power-rail refcount helper"
	default y
	depends on SOC_SERIES_APOLLO5X || SOC_SERIES_APOLLO4X
	depends on AMBIQ_HAL
	help
	  Reference-counted wrapper around am_hal_pwrctrl_periph_enable() /
	  _disable(). Drivers that share a power rail (OTP, CRYPTO, DISP)
	  acquire/release through this helper so the rail is only physically
	  toggled on the 0->1 / 1->0 edges. Required for safe concurrent use
	  of crypto + entropy (OTP) and any combination of the display drivers
	  (DSI/MIPI-DBI/JDI/SPI display controller).

if AMBIQ_PWRCTRL

config AMBIQ_PWRCTRL_HAS_OTP
	bool
	default y if SOC_SERIES_APOLLO5X
	help
	  Set on SoCs whose HAL exposes AM_HAL_PWRCTRL_PERIPH_OTP. The OTP
	  rail is only present on Apollo5X (incl. Apollo330P); Apollo4X
	  HAL headers do not define the symbol so OTP support is compiled
	  out and ambiq_pwrctrl_acquire(AMBIQ_PWRCTRL_OTP) returns -ENOTSUP.

module = AMBIQ_PWRCTRL
module-str = ambiq_pwrctrl
source "subsys/logging/Kconfig.template.log_config"

endif # AMBIQ_PWRCTRL
