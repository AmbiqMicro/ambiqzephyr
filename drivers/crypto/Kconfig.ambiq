config CRYPTO_AMBIQ_AES
	bool "Ambiq CryptoCell AES driver"
	default y
	depends on DT_HAS_AMBIQ_CRYPTO_AES_ENABLED
	select AMBIQ_HAL
	select POWER_DOMAIN
	help
		Enable the Ambiq CryptoCell-312 AES cipher driver.

		Supported cipher modes:
		- ECB
		- CTR
		- OFB
		- CCM
		- GCM
		- XTS
