config SOC_SERIES_APOLLO5X
	select ARM
	select CPU_CORTEX_M55
	select CPU_CORTEX_M_HAS_DWT
	select CPU_CORTEX_M_HAS_VTOR
	select CPU_HAS_ARM_SAU
	select CPU_HAS_ARM_MPU
	select CPU_HAS_FPU
	select ARMV8_M_DSP
	select ARMV8_1_M_MVEI
	select ARMV8_1_M_MVEF
	select ARMV8_1_M_PMU
	select HAS_SWO
	select AMBIQ_HAL
	select HAS_PM
	select SOC_EARLY_INIT_HOOK
	select REQUIRES_FULL_LIBC
	select SOC_AMBIQ_HAS_PUF
	select SOC_AMBIQ_HAS_CLKMGR
	select MEM_ATTR if CACHE_MANAGEMENT

config SOC_APOLLO510B
	select SOC_AMBIQ_BT_SUPPORTED

config SOC_APOLLO510B_EM9305_EXTREF_INIT
	bool "Wake SIP EM9305 for EXTREF clock"
	depends on SOC_APOLLO510B
	depends on DT_HAS_AMBIQ_BT_HCI_SPI_ENABLED
	select GPIO
	select SPI
	select AMBIQ_COMPONENT_USE_BT
	select AMBIQ_HAL_USE_TIMER
	help
	  Wake the SIP EM9305 over SPI and enable sleep so CLKMGR can use EXTREF
	  (~12 MHz). Uses ambiq,bt-hci-spi in devicetree; CONFIG_BT is not
	  required.

config SOC_APOLLO510B_EM9305_EXTREF_INIT_PRIORITY
	int "Apollo510B EM9305 EXTREF clock init priority"
	default 51
	depends on SOC_APOLLO510B_EM9305_EXTREF_INIT

if SOC_SERIES_APOLLO5X

config ARMV8_1_M_PMU_EVENTCNT
	int
	default 8

rsource "Kconfig.gpu"

endif
