config SOC_SERIES_APOLLO5X
	select ARM
	select CPU_CORTEX_M55
	select CPU_CORTEX_M_HAS_DWT
	select CPU_CORTEX_M_HAS_VTOR
	select CPU_HAS_ARM_SAU
	select CPU_HAS_ARM_MPU
	select CPU_HAS_FPU
	select ARMV8_M_DSP
	select ARMV8_1_M_MVEI
	select ARMV8_1_M_MVEF
	select ARMV8_1_M_PMU
	select HAS_SWO
	select AMBIQ_HAL
	select HAS_PM
	select SOC_EARLY_INIT_HOOK
	select REQUIRES_FULL_LIBC
	select SOC_AMBIQ_HAS_PUF
	select SOC_AMBIQ_HAS_CLKMGR

config SOC_APOLLO510B
	select SOC_AMBIQ_BT_SUPPORTED

config SOC_APOLLO510L
	select SOC_AMBIQ_BT_SUPPORTED
	select SOC_AMBIQ_HAS_CRM
	select SOC_AMBIQ_HAS_RSS

config SOC_APOLLO330P
	select SOC_AMBIQ_BT_SUPPORTED
	select SOC_AMBIQ_HAS_CRM
	select SOC_AMBIQ_HAS_RSS

config SOC_AMBIQ_APOLLO5X_BLE_LP
	bool "AmbiqSuite ble_freertos_fit_lp style early SoC init (330P/510L)"
	depends on SOC_APOLLO330P || SOC_APOLLO510L
	help
	  Align Zephyr early boot with boards/.../power/ble_freertos_fit_lp: LFRC for RTC,
	  XTAL power-down in deep sleep, DBGCTRL cleared, IOSFD0..NETAOL-1 peripheral power
	  gating (NETAOL/RSS kept), DTCM128K + NVM + ROM auto, SRAM 0.75M active/retain,
	  MRAM low-power bits, I/D cache off with CPDLP/cache power-down. Intended for
	  BLE + tickless idle; not for throughput-focused builds.

if SOC_SERIES_APOLLO5X

config SOC_AMBIQ_RSS_MGR
	bool "Radio subsystem manager functions"
	default y
	depends on SOC_AMBIQ_HAS_RSS
	depends on DT_HAS_VND_MBOX_CONSUMER_ENABLED || DT_HAS_AMBIQ_MBOX_IPC_ENABLED || DT_HAS_AMBIQ_USB_ENABLED
	select NET_BUF
	select MBOX
	help
	  This option includes the radio subsystem manager functions for Apollo510L.

config ARMV8_1_M_PMU_EVENTCNT
	int
	default 8

rsource "Kconfig.gpu"

endif
